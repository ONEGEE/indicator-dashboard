{
  "mode": "us_gics",
  "title": "美股轮动",
  "description": "S&P 500 GICS 一级行业（Sector）与二级行业组（Industry Group）相对强弱轮动（JdK RRG）。跟踪标准指数，不使用 ETF。",
  "taxonomy": "gics",
  "rrg": {
    "method": "jdk",
    "base_frequency": "daily",
    "frequency_options": [
      "daily",
      "weekly",
      "monthly",
      "yearly"
    ],
    "window": 14,
    "roc_period": 10,
    "trail_default": {
      "daily": 20,
      "weekly": 26,
      "monthly": 12,
      "yearly": 5
    },
    "notes": "GICS 一级默认展示；二级需先选一级行业再下钻。标准 JdK：动量由 RS-Ratio 变化率推导；JdK/ROC 随采样频率自动匹配（月 12/3）。同质行业组合易见顺时针轮动。",
    "default_level": "L1",
    "require_parent_for_l2": true,
    "default_cycle": "nber"
  },
