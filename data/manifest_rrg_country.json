{
  "mode": "country",
  "title": "主要国家指数轮动",
  "description": "全球主要国家/地区股票指数相对强弱轮动（JdK RRG）。基准可在列表中任选；MSCI 系列在 Yahoo 无纯指数时使用对应 MSCI ETF 代理并标注。",
  "taxonomy": "country_equity_index",
  "rrg": {
    "method": "jdk",
    "base_frequency": "daily",
    "frequency_options": [
      "daily",
      "weekly",
      "monthly",
      "yearly"
    ],
    "window": 14,
    "roc_period": 10,
    "trail_default": {
      "daily": 20,
      "weekly": 26,
      "monthly": 12,
      "yearly": 5
    },
    "notes": "按地区分组展示。标准 JdK 公式；JdK/ROC 随采样频率自动匹配。指数同类可比但各国周期不同步，顺时针弱于单一市场行业。",
    "default_cycle": "nber"
  },
